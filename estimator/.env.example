# --- estimator configuration -------------------------------------------------

# HTTP port (default 8080)
PORT=8080

# SQLite file (local auction/estimate state). Default: data/auctions.db
DB_PATH=data/auctions.db

# n8n Postgres-gateway webhooks. All central-DB access goes through n8n.
# Both required for estimation; if empty the dashboard + auction fetch still work.
#   LOOKUP: POST {"asins":[...]}  -> [{"asin":..,"price":..}, ...]
#   SAVE:   POST {product payload} -> writes products/translations/visual_search
N8N_LOOKUP_URL=
N8N_SAVE_URL=

# Long-lived Bearer token for jobalots download-manifest (does not expire).
JOBALOTS_MANIFEST_TOKEN=

# Competition-search-module trigger endpoint.
COMPETITION_MODULE_URL=https://competition-search-module-production.up.railway.app/competition-search

# Our jobalots user id — used to flag pallets where we are the top bidder.
OUR_USER_ID=59890

# Minutes before a stalled estimation is force-finalized as 'partial'.
ESTIMATE_TIMEOUT_MIN=15

# Set to 1 to disable the internal scheduler (e.g. if you drive refresh from n8n).
DISABLE_CRON=

# Next.js server-action id + router-state-tree for the auction list fetch.
# Only change these if jobalots redeploys their frontend and the fetch breaks.
# JOBALOTS_NEXT_ACTION=7f85c3b96b7f0e4740df33c5cbb862e11a3d68028e
# JOBALOTS_STATE_TREE=

# -----------------------------------------------------------------------------
# IMPORTANT: the competition-search-module must POST its results back to us.
# Set the MODULE's own WEBHOOK_URL env var to:
#   https://<this-service-public-url>/api/competition-callback
